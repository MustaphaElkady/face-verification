+"""Central device selection for CPU/GPU runtime.
+
+USE_GPU=false -> force CPU for InsightFace/ONNXRuntime, AdaFace/PyTorch, and EasyOCR.
+USE_GPU=true  -> use GPU when CUDA dependencies are available, otherwise fall back to CPU
+                 with a clear warning in logs.
+"""
+
+from __future__ import annotations
+
+import logging
+from typing import List, Tuple
+
+from core.config import settings
+
+logger = logging.getLogger(__name__)
+
+
+def torch_cuda_available() -> bool:
+    """Return True only when USE_GPU=true and PyTorch can see CUDA."""
+    if not settings.use_gpu:
+        return False
+
+    try:
+        import torch
+
+        available = bool(torch.cuda.is_available())
+        if not available:
+            logger.warning("USE_GPU=true but torch.cuda.is_available() is False. Using CPU for torch/EasyOCR.")
+        return available
+    except Exception as exc:
+        logger.warning("USE_GPU=true but PyTorch CUDA check failed: %s. Using CPU for torch/EasyOCR.", exc)
+        return False
+
+
+def torch_device() -> str:
+    return "cuda:0" if torch_cuda_available() else "cpu"
+
+
+def easyocr_gpu_enabled() -> bool:
+    """EasyOCR uses PyTorch, so this follows the PyTorch CUDA check."""
+    return torch_cuda_available()
+
+
+def onnxruntime_execution() -> Tuple[List[str], int, str]:
+    """Return providers, ctx_id, and device label for InsightFace/ONNXRuntime.
+
+    ctx_id=0  -> GPU
+    ctx_id=-1 -> CPU
+    """
+    cpu = (["CPUExecutionProvider"], -1, "CPU")
+
+    if not settings.use_gpu:
+        return cpu
+
+    try:
+        import onnxruntime as ort
+
+        # Safe no-op on versions/platforms where this helper does not exist.
+        if hasattr(ort, "preload_dlls"):
+            try:
+                ort.preload_dlls()
+            except Exception as exc:
+                logger.warning("ONNXRuntime CUDA DLL preload failed: %s", exc)
+
+        available = ort.get_available_providers()
+        if "CUDAExecutionProvider" in available:
+            return (["CUDAExecutionProvider", "CPUExecutionProvider"], 0, "GPU")
+
+        logger.warning(
+            "USE_GPU=true but CUDAExecutionProvider is not available in ONNXRuntime. "
+            "Available providers=%s. Using CPU for InsightFace.",
+            available,
+        )
+        return cpu
+    except Exception as exc:
+        logger.warning("USE_GPU=true but ONNXRuntime CUDA check failed: %s. Using CPU for InsightFace.", exc)
+        return cpu
