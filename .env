# ── Model ─────────────────────────────────────────────────────────────────────
# Backend: "insightface" (default) | "adaface" (requires: pip install torch adaface-pytorch)
FACE_MODEL_BACKEND="insightface"
FACE_MODEL_NAME="buffalo_l"
USE_GPU="true"

# ── Decision thresholds ────────────────────────────────────────────────────────
# score >= SIMILARITY_THRESHOLD       → VERIFIED
# score >= MANUAL_REVIEW_THRESHOLD    → MANUAL_REVIEW (gray zone, route to human)
# score <  MANUAL_REVIEW_THRESHOLD    → REJECTED
SIMILARITY_THRESHOLD=0.62
MANUAL_REVIEW_THRESHOLD=0.45

# Minimum InsightFace detection confidence. Faces below this are too low
# quality for reliable embedding extraction.
MIN_DET_SCORE=0.58

# ── Image limits ───────────────────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10.0
MAX_IMAGE_DIMENSION=4096

# ── Quality validator thresholds (override defaults if needed) ─────────────────
BLUR_THRESHOLD_SELFIE=30
BLUR_THRESHOLD_DOCUMENT=20
BRIGHTNESS_LOW=55
BRIGHTNESS_HIGH=235
GLARE_RATIO=-50
MIN_FACE_RATIO=0.04

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000